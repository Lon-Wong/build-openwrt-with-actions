# ====================== 基础平台 ======================
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_DEVICE_ramips_mt7621_jdcloud_re_cp_02=y

# ====================== 32M闪存分区 ======================
CONFIG_TARGET_KERNEL_PARTSIZE=16
CONFIG_TARGET_ROOTFS_PARTSIZE=16

# ====================== 512MB内存 ======================
CONFIG_DDR_SIZE=512

# ====================== CPU & Drivers ======================
CONFIG_MT7621_NAND=n
CONFIG_MT7621_SPI=y
CONFIG_MT7621_ETH=y
CONFIG_MT7621_WDT=y
CONFIG_MT7621_GPIO=y

# ====================== 文件系统 ======================
CONFIG_TARGET_IMAGES_SQUASHFS=y
CONFIG_TARGET_IMAGES_EXT4=y

# ====================== 基础LuCI & 常用 ======================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-i18n-zh-cn=y
CONFIG_PACKAGE_luci-app-network=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_ipv6=y

# ====================== 无线WiFi6驱动（鲁班 MT7915E WiFi6） ======================
CONFIG_WIRELESS=y
CONFIG_PACKAGE_wifi=y
CONFIG_PACKAGE_hostapd=y
CONFIG_PACKAGE_wpa_supplicant=y
CONFIG_PACKAGE_mt7621-wifi=y
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_wpad-mesh-openssl=y
CONFIG_PACKAGE_wireless-regdb=y

# ====================== 核心依赖 ======================
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-squashfs=y

# ====================== 精简无用组件 ======================
CONFIG_USB_SUPPORT=n
CONFIG_PACKAGE_kmod-usb-core=n
CONFIG_PACKAGE_kmod-usb-storage=n
CONFIG_DEVEL=n
CONFIG_EXTERNAL_TOOLCHAIN=n
