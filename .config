# Target
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_jdcloud_re_cp_02=y

# Flash 32MB
CONFIG_FLASH_SIZE=32
CONFIG_KERNEL_PARTSIZE=16
CONFIG_ROOTFS_PARTSIZE=14
CONFIG_SQUASHFS_BLOCKSIZE=262144
CONFIG_SQUASHFS_PAGESIZE=4096

# RAM 512MB
CONFIG_DDR_SIZE=512

# CPU & Drivers
CONFIG_MT7621_NAND=n
CONFIG_MT7621_SPI=y
CONFIG_MT7621_ETH=y
CONFIG_MT7621_WDT=y
CONFIG_MT7621_GPIO=y

# WiFi（鲁班 MT7915E WiFi6）
CONFIG_WIRELESS=y
CONFIG_PACKAGE_wifi=y
CONFIG_PACKAGE_hostapd=y
CONFIG_PACKAGE_wpa_supplicant=y
CONFIG_PACKAGE_mt7621-wifi=y
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_wireless-regdb=y

# Network
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-network=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_ipv6=y

# USB（鲁班无USB，关掉）
CONFIG_USB_SUPPORT=n
CONFIG_PACKAGE_kmod-usb-core=n

# Filesystems
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-squashfs=y

# Kernel
CONFIG_KERNEL_VERSION=5.4
CONFIG_KERNEL_CORE_COUNT=2

# 不压缩内核（32MB空间够）
CONFIG_KERNEL_COMPRESS_NONE=y

# 必选模块
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y

# Luci 中文
CONFIG_PACKAGE_luci-i18n-zh-cn=y

# 禁用无用包
CONFIG_DEVEL=n
CONFIG_EXTERNAL_TOOLCHAIN=n
